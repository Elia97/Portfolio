---
import ProjectLayout from "@/layouts/project.astro"
import Badge from "@/components/Badge.astro"
import { Icon } from "astro-icon/components"
import { buttonVariants } from "@/lib/button-variants"
import { getRelativeLocaleUrl } from "astro:i18n"
import { getTranslationDict } from "@/i18n"
import { motion } from "viewmotion"
import type { Translations } from "@/i18n/schema"

type ProjectItem = Translations["projects"]["items"][number]

export function getStaticPaths() {
  const { projects } = getTranslationDict("it")
  return projects.items.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }))
}

interface Props {
  project: ProjectItem
}

const { project } = Astro.props

const { projects } = getTranslationDict("it")
const currentIndex = projects.items.findIndex((p) => p.slug === project.slug)
const prevProject = projects.items[currentIndex - 1]
const nextProject = projects.items[currentIndex + 1]

const narrativeSections = [project.problem, project.solution, project.result]
---

<ProjectLayout
  title={`${project.title} — Caso studio`}
  description={project.description}
  alternateHref={getRelativeLocaleUrl("en", `/projects/${project.slug}`)}
>
  <main class="mx-auto max-w-3xl px-6 py-16 sm:py-24">
    <!-- Back -->
    <a
      href={getRelativeLocaleUrl("it", "/progetti")}
      {...motion({ preset: "fade-down", delay: 0 })}
      class="group mb-16 inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      <Icon
        name="arrow-left"
        class="h-4 w-4 transition-transform group-hover:-translate-x-1"
      />
      Torna ai progetti
    </a>

    <!-- Header -->
    <header class="space-y-4">
      <div
        {...motion({ preset: "fade-up", delay: 100 })}
        class="flex flex-wrap items-center gap-2"
      >
        <span class="font-mono text-sm text-primary">{project.year}</span>
      </div>

      <h1
        {...motion({ preset: "fade-up", delay: 200 })}
        class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl"
      >
        {project.title}
      </h1>

      <p
        {...motion({ preset: "fade-up", delay: 300 })}
        class="font-mono text-lg text-muted-foreground"
      >
        {project.subtitle}
      </p>
    </header>

    <!-- CTAs -->
    {
      (project.githubUrl || project.npmUrl) && (
        <div
          {...motion({ preset: "fade-up", delay: 400 })}
          class="mt-8 flex flex-wrap gap-3"
        >
          {project.githubUrl && (
            <a
              href={project.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class:list={buttonVariants({
                variant: "outline",
                size: "default",
              })}
            >
              <Icon name="github" class="mr-2 h-4 w-4" />
              GitHub
            </a>
          )}
          {project.npmUrl && (
            <a
              href={project.npmUrl}
              target="_blank"
              rel="noopener noreferrer"
              class:list={buttonVariants({
                variant: "outline",
                size: "default",
              })}
            >
              <Icon name="npm" class="mr-2 h-4 w-4" />
              npm
            </a>
          )}
        </div>
      )
    }

    <!-- Narrative -->
    <div class="mt-16 space-y-16">
      {
        narrativeSections.map((section) => (
          <section
            {...motion({ preset: "fade-up" })}
            class="space-y-6 border-t border-border pt-12"
          >
            <h2 class="font-mono text-xl font-bold">
              <span class="text-primary">{">"}</span> {section.heading}
            </h2>
            <p class="leading-relaxed text-muted-foreground">{section.body}</p>
            {section.highlights.length > 0 && (
              <ul class="space-y-2">
                {section.highlights.map((item) => (
                  <li class="flex items-start gap-3 text-sm text-muted-foreground">
                    <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-primary" />
                    {item}
                  </li>
                ))}
              </ul>
            )}
          </section>
        ))
      }
    </div>

    <!-- Features -->
    {
      project.features.length > 0 && (
        <section
          {...motion({ preset: "fade-up" })}
          class="mt-16 space-y-6 border-t border-border pt-12"
        >
          <h2 class="font-mono text-xl font-bold">
            <span class="text-primary">{">"}</span> Funzionalità
          </h2>
          <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            {project.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm text-muted-foreground">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-primary" />
                {feature}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <!-- Tech stack -->
    <footer
      {...motion({ preset: "fade-up" })}
      class="mt-16 space-y-6 border-t border-border pt-12"
    >
      <h2 class="font-mono text-xl font-bold">
        <span class="text-primary">{">"}</span> Stack tecnologico
      </h2>
      <div class="flex flex-wrap gap-2">
        {
          project.technologies.map((tech) => (
            <Badge variant="outline">{tech}</Badge>
          ))
        }
      </div>
    </footer>

    <!-- Navigazione tra progetti -->
    {
      (prevProject || nextProject) && (
        <nav
          {...motion({ preset: "fade-up" })}
          class="mt-16 grid grid-cols-2 gap-4 border-t border-border pt-12"
        >
          <div>
            {prevProject && (
              <a
                href={getRelativeLocaleUrl(
                  "it",
                  `/progetti/${prevProject.slug}`
                )}
                class="group flex flex-col gap-1"
              >
                <span class="flex items-center gap-1 text-xs text-muted-foreground">
                  <Icon name="arrow-left" class="h-3 w-3" />
                  Precedente
                </span>
                <span class="font-mono text-sm font-medium transition-colors group-hover:text-primary">
                  {prevProject.title}
                </span>
              </a>
            )}
          </div>
          <div class="text-right">
            {nextProject && (
              <a
                href={getRelativeLocaleUrl(
                  "it",
                  `/progetti/${nextProject.slug}`
                )}
                class="group flex flex-col items-end gap-1"
              >
                <span class="flex items-center gap-1 text-xs text-muted-foreground">
                  Successivo
                  <Icon name="arrow-right" class="h-3 w-3" />
                </span>
                <span class="font-mono text-sm font-medium transition-colors group-hover:text-primary">
                  {nextProject.title}
                </span>
              </a>
            )}
          </div>
        </nav>
      )
    }
  </main>
</ProjectLayout>
