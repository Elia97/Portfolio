---
import Layout from "@/layouts/website.astro"
import { getTranslations, getTranslationDict } from "@/i18n"
import CodeViewer from "@/components/sections/about/CodeViewer.astro"
import HeaderEffect from "@/components/HeaderEffect.astro"
import { motion } from "viewmotion"

const locale = Astro.currentLocale ?? "it"
const t = getTranslations(locale)
const dict = getTranslationDict(locale)
---

<Layout title={t("about.meta.title")} description={t("about.meta.description")}>
  <HeaderEffect {...motion({ preset: "blur-in", delay: 2000 })} />
  <CodeViewer {...dict.about.codeViewer} />
</Layout>
