---
import { getCollection, render } from "astro:content"
import { getRelativeLocaleUrl } from "astro:i18n"
import { Icon } from "astro-icon/components"
import { motion } from "viewmotion"
import BlogLayout from "@/layouts/blog.astro"
import Badge from "@/components/Badge.astro"
import FormattedDate from "@/components/blog/FormattedDate.astro"
import TableOfContents from "@/components/blog/TableOfContents.astro"
import SeriesNav from "@/components/blog/SeriesNav.astro"
import SeriesSidebar from "@/components/blog/SeriesSidebar.astro"
import { getTranslations } from "@/i18n"

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft)
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content, headings } = await render(entry)
const t = getTranslations("it")

const wordCount = entry.body?.split(/\s+/).filter(Boolean).length ?? 0
const readingTime = Math.max(1, Math.ceil(wordCount / 200))

const allPosts = await getCollection("blog", ({ data }) => !data.draft)
const seriesPosts = allPosts
  .filter((p) => p.data.series && p.data.series === entry.data.series)
  .sort((a, b) =>
    a.data.order !== undefined && b.data.order !== undefined
      ? a.data.order - b.data.order
      : a.data.pubDate.getTime() - b.data.pubDate.getTime()
  )

const seriesIndex = seriesPosts.findIndex((p) => p.id === entry.id)
const prevInSeries = seriesPosts[seriesIndex - 1]
const nextInSeries = seriesPosts[seriesIndex + 1]
---

<BlogLayout title={entry.data.title} description={entry.data.description}>
  <TableOfContents headings={headings} />
  {
    entry.data.series && (
      <SeriesSidebar
        posts={seriesPosts}
        currentId={entry.id}
        seriesTitle={entry.data.series}
      />
    )
  }

  <main class="mx-auto max-w-3xl px-6 py-12 sm:py-24">
    <a
      href={getRelativeLocaleUrl("it", "/blog")}
      {...motion({ preset: "fade-down", delay: 0, once: true })}
      class="group mb-12 inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      <Icon
        name="arrow-left"
        class="h-4 w-4 transition-transform group-hover:-translate-x-1"
      />
      {t("blog.ui.backLabel")}
    </a>

    <article>
      <header
        {...motion({ preset: "fade-up", delay: 100, once: true })}
        class="mb-12 space-y-4"
      >
        {
          entry.data.series && (
            <div class="flex items-center gap-3">
              <Badge variant="default" size="sm">
                {entry.data.series}
              </Badge>
              {entry.data.order !== undefined && (
                <span class="font-mono text-xs text-muted-foreground">
                  #{entry.data.order} / {seriesPosts.length}
                </span>
              )}
            </div>
          )
        }

        <h1 class="blog-article-title">
          {entry.data.title}
        </h1>

        <p class="blog-article-lede">
          {entry.data.description}
        </p>

        <div
          class="mt-3 flex flex-wrap items-center gap-3 font-mono text-sm text-muted-foreground"
        >
          <FormattedDate date={entry.data.pubDate} locale="it" />
          <span>·</span>
          <span>{readingTime} {t("blog.ui.readingTime")}</span>
          {
            entry.data.tags.length > 0 && (
              <>
                <span>·</span>
                <div class="flex flex-wrap gap-1">
                  {entry.data.tags.map((tag) => (
                    <Badge variant="outline" size="sm">
                      {tag}
                    </Badge>
                  ))}
                </div>
              </>
            )
          }
        </div>
      </header>

      <div
        {...motion({ preset: "fade-up", delay: 200, once: true })}
        class="prose-blog"
      >
        <Content />
      </div>

      {
        entry.data.series && (
          <div {...motion({ preset: "fade-up", once: true })} class="mt-12">
            <SeriesNav
              seriesTitle={entry.data.series}
              order={entry.data.order}
              total={seriesPosts.length}
              prev={
                prevInSeries
                  ? { title: prevInSeries.data.title, slug: prevInSeries.id }
                  : undefined
              }
              next={
                nextInSeries
                  ? { title: nextInSeries.data.title, slug: nextInSeries.id }
                  : undefined
              }
            />
          </div>
        )
      }
    </article>
  </main>
</BlogLayout>

<script>
  import "@/components/blog/scripts/toc.motion"
</script>
