---
import Layout from "@/layouts/website.astro"
import { getTranslations, getTranslationDict } from "@/i18n"
import { Hero, Stack, Services, Work } from "@/components/sections/home"

const locale = Astro.currentLocale ?? "en"
const t = getTranslations(locale)
const dict = getTranslationDict(locale)
---

<Layout title={t("home.meta.title")} description={t("home.meta.description")}>
  <Hero {...dict.home.hero} />
  <Stack {...dict.home.stack} />
  <Services {...dict.home.services} />
  <Work {...dict.home.work} />
</Layout>
