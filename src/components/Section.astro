---
import type { HTMLAttributes } from "astro/types"

interface Props extends HTMLAttributes<"section"> {
  align?: "start" | "center" | "end"
  class?: string
}

const { align = "start", class: className, ...props } = Astro.props
---

<section
  {...props}
  class:list={[
    "relative flex min-h-svh flex-col px-6 pt-(--section-pt) pb-12",
    {
      "items-center justify-center": align === "center",
      "items-end": align === "end",
    },
    className,
  ]}
>
  <slot />
</section>
