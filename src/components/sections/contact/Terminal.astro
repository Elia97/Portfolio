---
import { motion } from "viewmotion"
import type { Translations } from "@/i18n/schema"

type Props = Translations["contact"]["terminal"]

const {
  lastLogin,
  clickToStart,
  touchToStart,
  installing,
  installed,
  starting,
  ready,
  protocol,
  opening,
  reclick,
  promptPath,
  command,
  email,
} = Astro.props
---

<div
  {...motion({ preset: "scale-in", delay: 800 })}
  class="relative mx-auto w-full max-w-xl lg:px-6"
  data-terminal-container
  data-installing={installing}
  data-installed={installed}
  data-starting={starting}
  data-ready={ready}
  data-protocol={protocol}
  data-opening={opening}
  data-reclick={reclick}
  data-command={command}
  data-email={email}
>
  <div
    data-terminal-window
    class="group transform cursor-text overflow-hidden border border-terminal-border bg-terminal-bg font-mono text-sm shadow-2xl transition-transform duration-300 hover:scale-[1.01] md:text-base"
  >
    <div
      class="flex items-center space-x-2 border-b border-terminal-border bg-terminal-header px-4 py-2"
    >
      <div class="flex space-x-1.5">
        <div class="h-3 w-3 rounded-full bg-terminal-dot-red"></div>
        <div class="h-3 w-3 rounded-full bg-terminal-dot-yellow"></div>
        <div class="h-3 w-3 rounded-full bg-terminal-dot-green"></div>
      </div>
      <div
        class="flex-1 text-center text-xs text-terminal-text-muted select-none"
      >
        {promptPath}
      </div>
    </div>

    <div
      class="relative flex h-96 flex-col p-6 text-terminal-text"
      data-terminal-body
    >
      <div class="mb-4 text-terminal-text-muted select-none">
        {lastLogin}: <span data-terminal-date></span> on ttys000
      </div>

      <div class="flex-1 overflow-hidden">
        <div data-terminal-output class="wrap-break-word whitespace-pre-wrap">
        </div>
        <div class="mt-2 flex items-center">
          <span class="mr-2 text-success">➜</span>
          <span class="mr-2 text-terminal-prompt">~</span>
          <span data-terminal-input class="text-terminal-text"></span>
          <span
            data-terminal-cursor
            class="ml-1 h-5 w-2.5 animate-pulse bg-terminal-cursor"></span>
        </div>
      </div>

      <div
        class="pointer-events-none absolute right-4 bottom-4 flex animate-pulse items-center gap-2 text-xs text-terminal-text-muted"
      >
        <span class="hidden xl:inline">{clickToStart}</span>
        <span class="xl:hidden">{touchToStart}</span>
        <span class="h-2 w-2 rounded-full bg-terminal-dot-green"></span>
      </div>
    </div>
  </div>
</div>

<script>
  import "@/components/sections/contact/scripts/terminal.motion"
</script>
