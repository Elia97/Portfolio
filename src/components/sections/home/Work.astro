---
import { motion } from "viewmotion"
import type { Translations } from "@/i18n/schema"
import svg0 from "@/assets/image1.svg?raw"
import svg1 from "@/assets/image2.svg?raw"
import svg2 from "@/assets/image3.svg?raw"

type Props = Translations["home"]["work"]

const svgs = [svg0, svg1, svg2]
---

<section data-work-section class="relative">
  <!-- ── Desktop: GSAP horizontal scroll ─────────────────────────────── -->
  <div data-work-desktop class="hidden lg:block">
    <div data-work-sticky class="relative h-svh overflow-hidden">
      <div data-work-track class="flex h-full">
        {
          Astro.props.items.map((item, index) => (
            <article
              data-work-panel
              class="flex h-full w-screen shrink-0 flex-row items-center gap-0"
            >
              <div class="flex h-[80%] w-1/2 items-center justify-center border-r border-border px-16 xl:px-20">
                <div
                  data-work-illustration
                  set:html={svgs[index]}
                  class="w-full [&>svg]:h-auto [&>svg]:w-full"
                />
              </div>

              <div
                data-work-text
                class="flex w-1/2 flex-col gap-4 px-12 xl:px-16 2xl:px-20"
              >
                <p class="font-mono text-xs tracking-[0.2em] text-primary uppercase">
                  {item.label}
                </p>
                <h3 class="text-4xl font-semibold xl:text-5xl 2xl:text-6xl">
                  {item.title}
                </h3>
                <p
                  class="text-sm xl:text-base 2xl:text-xl"
                  set:html={item.description}
                />
              </div>
            </article>
          ))
        }
      </div>

      <div
        data-work-progress
        class="pointer-events-none absolute bottom-8 left-1/2 flex -translate-x-1/2 gap-2"
        aria-hidden="true"
      >
        {
          Astro.props.items.map(() => (
            <div data-work-dot class="h-1 w-4 rounded-full bg-border" />
          ))
        }
      </div>
    </div>
  </div>

  <!-- ── Mobile: viewmotion vertical stack ────────────────────────────── -->
  <div class="flex flex-col lg:hidden">
    {
      Astro.props.items.map((item, index) => (
        <div class="flex flex-col items-center justify-center gap-8 px-6 py-16">
          <div
            {...motion({ preset: "fade-up" })}
            set:html={svgs[index]}
            class="w-full max-w-xs sm:max-w-sm [&>svg]:h-auto [&>svg]:w-full"
          />

          <div class="flex w-full flex-col gap-4">
            <p
              {...motion({ preset: "fade-up" })}
              class="font-mono text-xs tracking-[0.2em] text-primary uppercase"
            >
              {item.label}
            </p>
            <h3
              {...motion({ preset: "fade-up", delay: 80 })}
              class="text-2xl font-semibold sm:text-3xl"
            >
              {item.title}
            </h3>
            <p
              {...motion({ preset: "fade-up", delay: 160 })}
              class="text-sm xl:text-base 2xl:text-xl"
            >
              {item.description}
            </p>
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  import "@/components/sections/home/scripts/work.motion"
</script>
