---
import type { CollectionEntry } from "astro:content"
import { getTranslations } from "@/i18n"

interface Props {
  posts: CollectionEntry<"blog">[]
}

const { posts } = Astro.props
const locale = Astro.currentLocale ?? "it"
const t = getTranslations(locale)

const seriesMap = new Map<string, number>()
for (const post of posts) {
  if (post.data.series) {
    seriesMap.set(post.data.series, (seriesMap.get(post.data.series) ?? 0) + 1)
  }
}
---

{
  seriesMap.size > 0 && (
    <aside class="hidden xl:block">
      <div class="border-l border-border pl-8 xl:sticky xl:top-24">
        <p class="mb-5 font-mono text-xs font-semibold tracking-widest text-primary uppercase">
          {t("blog.ui.seriesLabel")}
        </p>
        <ul class="space-y-0.5">
          {[...seriesMap.entries()].map(([name, count]) => (
            <li>
              <a
                href={`#series-${name.toLowerCase().replace(/\s+/g, "-")}`}
                class="group flex items-baseline justify-between gap-3 py-2 text-muted-foreground transition-colors hover:text-foreground"
              >
                <span class="truncate font-mono text-xs leading-relaxed">
                  {name}
                </span>
                <span class="shrink-0 font-mono text-xs tabular-nums opacity-40 transition-opacity group-hover:opacity-70">
                  {count}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </aside>
  )
}
