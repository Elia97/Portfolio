---
import { Icon } from "astro-icon/components"
import { getRelativeLocaleUrl } from "astro:i18n"
import { getTranslations } from "@/i18n"

interface SeriesPost {
  title: string
  slug: string
}

interface Props {
  seriesTitle: string
  order?: number
  total: number
  prev?: SeriesPost
  next?: SeriesPost
}

const { seriesTitle, order, total, prev, next } = Astro.props
const locale = Astro.currentLocale ?? "it"
const t = getTranslations(locale)
---

<div class="space-y-4 rounded-lg border border-border bg-muted/20 p-6">
  <div class="flex items-center gap-2">
    <span
      class="font-mono text-xs font-semibold tracking-widest text-primary uppercase"
    >
      {t("blog.ui.seriesLabel")}
    </span>
    <span class="text-xs text-muted-foreground">·</span>
    <span class="font-mono text-sm font-medium">{seriesTitle}</span>
    {
      order !== undefined && (
        <span class="ml-auto font-mono text-xs text-muted-foreground">
          {order} / {total}
        </span>
      )
    }
  </div>

  {
    (prev || next) && (
      <div class="grid grid-cols-2 gap-4 border-t border-border pt-4">
        <div>
          {prev && (
            <a
              href={getRelativeLocaleUrl(locale, `/blog/${prev.slug}`)}
              class="group flex flex-col gap-1"
            >
              <span class="flex items-center gap-1 text-xs text-muted-foreground">
                <Icon name="arrow-left" class="h-3 w-3" />
                {t("blog.ui.prevInSeries")}
              </span>
              <span class="line-clamp-2 font-mono text-sm font-medium transition-colors group-hover:text-primary">
                {prev.title}
              </span>
            </a>
          )}
        </div>
        <div class="text-right">
          {next && (
            <a
              href={getRelativeLocaleUrl(locale, `/blog/${next.slug}`)}
              class="group flex flex-col items-end gap-1"
            >
              <span class="flex items-center gap-1 text-xs text-muted-foreground">
                {t("blog.ui.nextInSeries")}
                <Icon name="arrow-right" class="h-3 w-3" />
              </span>
              <span class="line-clamp-2 font-mono text-sm font-medium transition-colors group-hover:text-primary">
                {next.title}
              </span>
            </a>
          )}
        </div>
      </div>
    )
  }
</div>
