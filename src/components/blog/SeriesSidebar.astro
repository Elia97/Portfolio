---
import type { CollectionEntry } from "astro:content"
import { getRelativeLocaleUrl } from "astro:i18n"

interface Props {
  posts: CollectionEntry<"blog">[]
  currentId: string
  seriesTitle: string
}

const { posts, currentId, seriesTitle } = Astro.props
const locale = Astro.currentLocale ?? "it"
---

<nav
  aria-label={seriesTitle}
  transition:name="series-sidebar"
  transition:animate="none"
  class="fixed top-24 left-12 z-20 hidden w-60 xl:block 2xl:top-48 2xl:left-48 2xl:w-100"
>
  <p
    class="mb-3 truncate font-mono font-semibold tracking-widest text-muted-foreground uppercase 2xl:text-[11px]"
  >
    {seriesTitle}
  </p>

  <ul class="space-y-2 border-r border-border pr-4">
    {
      posts.map((post, i) => {
        const isCurrent = post.id === currentId
        return (
          <li>
            <a
              href={getRelativeLocaleUrl(locale, `/blog/${post.id}/`)}
              aria-current={isCurrent ? "page" : undefined}
              class:list={[
                "flex items-start gap-2 py-1 transition-colors xl:text-[14px] 2xl:text-[16px]",
                isCurrent
                  ? "font-semibold text-primary"
                  : "text-muted-foreground hover:text-foreground",
              ]}
            >
              <span
                class:list={[
                  "mt-0.5 w-5 shrink-0 text-right font-mono xl:text-[10px] 2xl:text-[12px]",
                  isCurrent ? "opacity-100" : "opacity-30",
                ]}
              >
                {String(i + 1).padStart(2, "0")}
              </span>
              <span class="line-clamp-2 leading-5">{post.data.title}</span>
            </a>
          </li>
        )
      })
    }
  </ul>
</nav>
