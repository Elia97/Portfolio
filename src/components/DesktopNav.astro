---
import type { NavItem } from "@/i18n/schema"
import { getRelativeLocaleUrl } from "astro:i18n"

interface Props {
  items: NavItem[]
}

const { items } = Astro.props
const locale = Astro.currentLocale ?? "it"
const pathname = Astro.url.pathname

const resolveHref = (href: string) => getRelativeLocaleUrl(locale, href)

const isActive = (href: string) => {
  const resolved = resolveHref(href)
  return href === "/" ? pathname === resolved : pathname.startsWith(resolved)
}

const linkStyle =
  "inline-flex gap-3 px-6 py-3 font-medium outline-none transition-[color,box-shadow] duration-300 hover:bg-muted hover:text-muted-foreground focus-visible:ring-[3px] focus-visible:ring-ring/50 focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 lg:text-sm xl:text-base 2xl:text-xl"
---

<nav
  class="mx-auto hidden w-fit border border-border bg-card shadow-2xl backdrop-blur-sm lg:block"
>
  <ul class="flex items-center">
    {
      items.map((item) => (
        <li class="relative">
          <a
            href={resolveHref(item.href)}
            class:list={[linkStyle, isActive(item.href) && "text-primary"]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
          {isActive(item.href) && (
            <span
              class="absolute bottom-0 left-0 h-0.5 w-full bg-primary"
              transition:name="nav-indicator"
            />
          )}
        </li>
      ))
    }
  </ul>
</nav>
