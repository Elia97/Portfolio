---
import MainLayout from "./main.astro"
import ThemeToggle from "@/components/ThemeToggle.astro"
import LanguageSwitcher from "@/components/LanguageSwitcher.astro"
import "@/styles/blog.css"

interface Props {
  title?: string
  description?: string
  image?: string
  noindex?: boolean
}

const { title, description, image, noindex } = Astro.props
---

<MainLayout
  title={title}
  description={description}
  image={image}
  noindex={noindex}
>
  <body>
    <div
      data-progress-bar
      aria-hidden="true"
      class="pointer-events-none fixed top-0 left-0 z-50 h-1.5 w-full origin-left bg-primary"
      style="transform: scaleX(0)"
    >
    </div>

    <div class="fixed top-4 right-6 z-40 flex items-center gap-1">
      <ThemeToggle />
      <LanguageSwitcher alternateHref="/en/blog" />
    </div>

    <slot />
  </body>
</MainLayout>

<script>
  import { createSignal } from "@/lib/create-signal"

  const getSignal = createSignal()

  function setup() {
    const signal = getSignal()
    const bar = document.querySelector<HTMLElement>("[data-progress-bar]")
    if (!bar) return

    bar.style.opacity = ""

    const update = () => {
      const scrollable =
        document.documentElement.scrollHeight - window.innerHeight
      bar.style.transform =
        scrollable > 0 ? `scaleX(${window.scrollY / scrollable})` : "scaleX(0)"
    }

    window.addEventListener("scroll", update, { passive: true, signal })
    update()
  }

  function hide() {
    const bar = document.querySelector<HTMLElement>("[data-progress-bar]")
    if (!bar) return
    bar.style.opacity = "0"
    bar.style.transform = "scaleX(0)"
  }

  document.addEventListener("astro:page-load", setup)
  document.addEventListener("astro:before-preparation", () => {
    hide()
    // Porta lo scroll a zero prima che la transizione parta visivamente,
    // evitando il salto percepibile a metà del fade
    window.scrollTo({ top: 0, behavior: "instant" })
  })
</script>
