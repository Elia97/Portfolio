---
import Head from "@/components/Head.astro"
import { getTranslations } from "@/i18n"

interface Props {
  title?: string
  description?: string
  image?: string
  noindex?: boolean
  article?: boolean
}

const locale = Astro.currentLocale ?? "it"
const t = getTranslations(locale)
const {
  title,
  description = t("site.description"),
  image,
  noindex,
  article,
} = Astro.props
---

<html lang={locale}>
  <Head
    title={title}
    description={description}
    image={image}
    noindex={noindex}
    article={article}
    locale={locale}
  />
  <slot />
</html>
